# get_pathopt
# @description Validate and return a pathname
#
# Arguments:
# @arg $1 string Optional -r flag for realpath
# @arg $2 string Path to verify
# @arg $3 string-ref Variable to receive validated path
#
# Returns:
# @exitcode 0 Path valid
# @exitcode * Exits if path invalid
#
get_pathopt() {
	local b_real=false
	[[ "$1" == "-r" ]] && b_real=true && shift
	local path="$1"
	local -a pathary=( $path )
	local -a  pary=()
	local -n optname="$2"

	for p in ${pathary[@]}; do
		[ -e "$p" ] || exitme $exit_invpath "$path"
		$b_real && p="$(realpath "$p")"
		pary+=( "$p" )
	done

	optname="${pary[@]}"
	return 0
}

# get_varopt
# @description Replace commas with spaces in variable list
#
# Arguments:
# @arg $1 string Variables separated by commas
# @arg $2 string-ref Variable to receive space-separated string
#
# Returns:
# @exitcode 0 Always succeeds
#
get_varopt() {
	local var="$1"
	local -n varname="$2"

	varname="${var//,/ }"
	return 0
}

# test_help
# @description Check if argument requests help
#
# Arguments:
# @arg $1 string String to check for help request
#
# Returns:
# @exitcode 0 Help requested (exits after showing usage)
#
test_help() {
	local opt="$1"

	shopt -s nocasematch
	[[ $opt =~ (h|help) ]] && { usage; exitme $exit_ok; }
	shopt -u nocasematch
	return 0
}

# is_validcmtexpr
# @description Validate an upstream commit expression
#   Breaks expression on double-dot and validates each commit.
#
# Arguments:
# @arg $1 string Commit expression to validate
#
# Globals:
# @set updir string Upstream repo directory (read)
#
# Returns:
# @exitcode 0 Valid expression
# @exitcode * Exits if invalid
#
is_validcmtexpr() {
	local tmp="$1"
	local -a cary=()
	local c
	local errstr=
	local stat

	ui_cd "$updir"
	cary=(${tmp//../ })

	for c in ${cary[@]}; do
		errstr="$(git rev-parse $c 2>&1 > /dev/null)"
		stat=$?
		((stat == 0)) || exitme "$exit_invhash" "$errstr\n$c"
	done

	ui_cd -
	return 0
}

# get_khashsize
# @description Print the number of characters in kernel hash
#
# Globals:
# @set updir string Upstream kernel directory (read)
#
# Effects:
# @stdout Hash size as integer
#
# Returns:
# @exitcode 0 Always succeeds
#
get_khashsize() {
	local cmt

	ui_cd "$updir"
	cmt="$(gitnice -1 | cut -d' ' -f1)"
	echo "${#cmt}"
	ui_cd -
}

# getcmt
# @description Validate commit expression from command line
#
# Arguments:
# @arg $1 string Commit expression
# @arg $2 string Switch name for error message
# @arg $3 string Variable to receive validated expression
#
# Returns:
# @exitcode 0 Valid commit
# @exitcode * Exits if invalid
#
getcmt() {
	local tmp="$1"
	local op="$2"
	local -n cmtname="$3"
	local -i stat=0

	is_validcmtexpr "$1"
	stat=$?

	((stat == 0)) || exitme $stat "$op $tmp"

	cmtname="$tmp"
	return 0
}

# parseops
# @description Parse input options for non-interactive command line
#
# Arguments:
# @arg $@ All command line arguments
#
# Globals:
# @set outdir string Output directory
# @set updir string Upstream directory
# @set path string Paths to search
# @set configtable array Config variables
#
# Returns:
# @exitcode 0 Options parsed successfully
#
parseops() {
	local arg=
	local opt=
	path=	# must init the path var, because it is aggregated.

	while (($# > 0)); do
	    arg="$1"

	    if [ "${arg:0:1}" == '-' ]; then
		opt="${arg:1}"

		shift
		case "$opt" in
		    ud ) get_pathopt -r "$1" updir
			 b_localus=false
			 ;;
		    od ) get_pathopt -r "$1" configtable[outdir]
			;;
		    dc ) getcmt "$1" "$arg" configtable[dncmt]
			 # Clear cached upcmt so it's freshly extracted from new -dc
			 upcmt=
			 configtable[upcmt]=
			 ;;
		    us ) getcmt "$1" "$arg" configtable[upcmt]
			 ;;
		    ue ) getcmt "$1" "$arg" configtable[upscope]
			 ;;
		    ub ) # Check if next arg is a branch name (not another option or path)
			 if [[ -n "$1" && "${1:0:1}" != "-" && ! -e "$1" ]]; then
			     set_upstream_branch "$1"
			 else
			     select_remote
			 fi
			 ;;
		    S  ) get_varopt "$1" configtable[searchstr]
			 ;;
		    ip ) b_include_prereqs=true
			 # Don't shift - no argument for this flag
			 continue
			 ;;
		    V  ) echo "Patchtools v$version"
			 exit 0
			 ;;
		    *  ) echo "unrecognized option $arg"
			 echo -e "$usagestr"
			 exit 127
		esac

	    elif [ -e "$arg" ]; then
			path="$path $arg"
	    fi

	    shift
	done

	configtable[path]="${path##*( )}"
	cfg_write
	return 0
}

# detect_prerequisite_gaps
# @description Detect upstream commits that may be missing prerequisites
#   Looks for upstream commits that touch our paths, are chronologically
#   BEFORE the "Upstream Start commit", but are NOT in downstream.
#   These are potential prerequisites that could cause conflicts.
#
# Arguments:
# @arg $1 string File to write gap commits to (optional)
#
# Globals:
# @set updir string Upstream directory (read)
# @set upbase string Upstream base version (read)
# @set upcmt string Upstream start commit (read)
# @set path string Paths to search (read)
# @set outdir string Output directory (read)
#
# Effects:
# @stdout Warning messages about detected gaps
#
# Returns:
# @exitcode 0 No gaps detected
# @exitcode 1 Gaps detected (potential missing prerequisites)
#
detect_prerequisite_gaps() {
	local gapfile="${1:-}"
	local -a gap_commits=()
	local line
	local commit
	local commit_date
	local upcmt_date
	local -i gap_count=0
	local -i total_checked=0

	# Debug output
	echo -e "${INF}Gap detection: upbase=$upbase upcmt=$upcmt$OFF" >&2
	echo -e "${INF}Gap detection: updir=$updir path=$path$OFF" >&2

	# Get the date of the upstream start commit for comparison
	ui_cd "$updir"
	upcmt_date=$(git log -1 --format='%ci' "$upcmt" 2>/dev/null | cut -d' ' -f1)

	echo -e "${INF}Gap detection: checking range $upbase..$upcmt^$OFF" >&2

	# Get all upstream commits touching our paths between upbase and upcmt
	# These are commits that are BEFORE our starting point
	while read -r line; do
		[ -z "$line" ] && continue
		commit=$(echo "$line" | cut -d' ' -f1)
		((total_checked++))

		# Check if this commit is already in downstream
		# by searching for it in downstream commit messages
		if ! git -C "$OLDPWD" log --oneline --all --grep="$commit" -- $path 2>/dev/null | grep -q .; then
			# Not in downstream - this is a potential gap
			gap_commits+=("$line")
			((gap_count++))
		fi
	done < <(gitnice -r -c -d --no-merges "$upbase..$upcmt^" $path 2>/dev/null)

	echo -e "${INF}Gap detection: checked $total_checked commits, found $gap_count gaps$OFF" >&2

	ui_cd -

	if ((gap_count > 0)); then
		echo -e "\n${WRN}WARNING: Detected $gap_count potential prerequisite commit(s)$OFF"
		echo -e "${INF}These upstream commits touch your paths but are BEFORE your starting point"
		echo -e "and are NOT in downstream. They may be prerequisites for later commits.$OFF\n"

		for line in "${gap_commits[@]}"; do
			echo -e "${CAU}  $line$OFF"
		done

		echo -e "\n${INF}Consider using an earlier -dc commit or manually adding these to backport.log$OFF"

		# Write gaps to file if requested
		if [[ -n "$gapfile" ]]; then
			printf "# PREREQUISITE GAPS - commits before starting point not in downstream\n" > "$gapfile"
			printf "%s\n" "${gap_commits[@]}" >> "$gapfile"
		fi

		return 1
	fi

	return 0
}

# compare_strings
# @description Create backport.log by comparing upstream/downstream commits
#   Marks already-backported commits with leading #
#
# Globals:
# @set bplog string Backport log filename
# @set uplog string Upstream log filename
# @set dnlog string Downstream log filename
# @set outdir string Output directory
#
# Effects:
# @stdout Progress output
#
# Returns:
# @exitcode 0 Always succeeds
#
compare_strings() {
	local uppath="$outdir/$uplog"
	local dnpath="$outdir/$dnlog"
	local chpath="$outdir/$bplog"
	local savedifs="$IFS"
	local upstr=
	local rhstr=
	local up	# one line from the upstream log
	local tmp
	local b_match=false
	local j		# upstr index
	local k		# rhstr index
	local rhcmt=

	# Instead of reading from the file, which limmits our debug
	# capabilites, create an array out of the lines in the file.
	# Set IFS to newline and then restore it after creating the
	# string arrays.
	#
	IFS=$'\n'
	upstr=($(< "$uppath"))
	rhstr=($(< "$dnpath"))
	IFS="$savedifs"

	# Zero the backport log file.
	:> "$chpath"

	for ((j = 0; j < ${#upstr[@]}; ++j)); do
		up=${upstr[j]}
		upcmt="${up:0:$khashsize}"

		for ((k = 0; k < ${#rhstr[@]}; ++k)); do
			tmp=$(echo "${rhstr[k]}" | cut -d' ' -f1)
			rhcmt="${tmp:0:$khashsize}"

			[[ "$rhcmt" == "$upcmt" ]] && {
				b_match=true
				break
			}
		done

		$b_match && echo "# $up" >> "$chpath" || echo "$up" >> "$chpath"
		$b_match && echo "# $up" || echo "$up"
		b_match=false
	done
	return 0
}

# init_env
# @description Initialize sticky variables and environment
#
# Globals:
# @set configfile string Config file path
# @set configtable array Config variables
# @set MYDATA string Data directory path
#
# Returns:
# @exitcode 0 Always succeeds
#
init_env() {
	local bgtemp

	[ -d "$MYDATA" ] || mkdir -p "$MYDATA"

	ui_setbg bgtemp

	cfg_start configtable "$configfile"
	background="$bgtemp"
	configtable[background]="$background"
	currentbranch=$(get_currentbranch)
	configtable[currentbranch]="$currentbranch"
	cfg_write
	return 0
}

# check_log
# @description Notify user if logfile already exists
#
# Arguments:
# @arg $1 string Logfile path to check
#
# Effects:
# @stdout Warning if file exists
#
# Returns:
# @exitcode 0 Always succeeds
#
check_log() {
	log="$1"

	echo -e "${INF}Create : $STA$log$OFF"

	[ -f "$log" ] && {
		echo -en "$WRN$log exists.$OFF "
		echo -e "${INF}It will be overwritten if you continue.$OFF"
	}
	return 0
}

# get_currentbranch
# @description Echo the current git branch
#
# Effects:
# @stdout Current branch name
#
# Returns:
# @exitcode 0 Always succeeds
#
get_currentbranch() {
	git branch | grep -E '^\*' | cut -d' ' -f2
}

# seek_str
# @description Search for string in commits from upstream.log
#
# Globals:
# @set updir string Upstream directory (read)
# @set outdir string Output directory (read)
# @set bplog string Backport log filename (read)
#
# Effects:
# @stdout Matching commits
#
# Returns:
# @exitcode 0 Always succeeds
#
seek_str() {
	local prepend=
	local outfile=
	local commit
	local str

	ui_cd "$updir"
	for str in $searchstr; do
		prepend=$(echo "$str" | cut -d' ' -f1)
		outfile="$outdir/$prepend-$bplog"

		echo -e "\n${STA}Creating $outfile$INF"
		: > "$outfile"
		while read -r line; do
			[ "${line:0:1}" == "#" ] && continue
			commit=$(echo "$line" | cut -d' ' -f1)
			git show "$commit" | grep -q -m1 "$str" || continue
			echo "$line" | tee -a "$outfile"
		done < "$outdir/$bplog"
	done
	ui_cd -
	return 0
}

# set_upstream_branch
# @description Set upstream branch directly from command line argument
#
# Arguments:
# @arg $1 string Branch name (e.g., origin/master)
#
# Globals:
# @set repobr string Selected remote branch (written)
# @set configtable array Config variables (written)
# @set updir string Upstream directory (read)
#
# Returns:
# @exitcode 0 Branch set successfully
# @exitcode 1 Branch not found in upstream repo
#
set_upstream_branch() {
	local branch="$1"
	local brstr=

	# Get all branches from upstream repo
	if [[ "$updir" != "$PWD" ]]; then
		ui_cd "$updir"
		brstr=$(git branch -r)
		ui_cd -
	else
		brstr=$(git branch -r)
	fi

	# Check if the specified branch exists (handle leading whitespace)
	if echo "$brstr" | grep -qE "(^|[[:space:]])${branch}$"; then
		repobr="$branch"
		configtable[repobr]="$repobr"
		echo -e "${INF}Using upstream branch: $STA$repobr$OFF"
		return 0
	else
		echo -e "${WRN}Branch '$branch' not found in upstream repo: $STA$updir$OFF"
		echo -e "${INF}Falling back to interactive selection...$OFF"
		select_remote
		return $?
	fi
}

# select_remote
# @description Choose from available repo/branches in current directory
#
# Globals:
# @set updir string Upstream directory (read)
# @set repobr string Selected repo/branch (written)
# @set configtable array Config variables (written)
#
# Effects:
# @stdout Branch selection menu
#
# Returns:
# @exitcode 0 Branch selected
# @exitcode 1 No remote upstream repo found
#
select_remote() {
	local brstr=
	local brancharray=()

	# Get all the branches into one string

	if [[ "$updir" != "$PWD" ]]; then
		ui_cd "$updir"
		brstr=$(git branch -r)
		ui_cd -
	else
		# We have a remote in PWD
		# Skip all the remotes that are from the origin or $USER.
		# We are only interested in upstream remotes in PWD
		brstr=$(git branch -r | grep -E -v "origin|$USER")
	fi

	# Filter out lines with '-> in them, because they are not branches
	while read -r s; do [[ $s == *"->"* ]] || brancharray+=("$s"); done <<< "$brstr"

	if [ -z "$brstr" ]; then
		echo -e "${WRN}There is no remote upstream repo in directory: $STA$updir$OFF"
		return 1
	fi

	if [ ${#brancharray[@]} -gt 1 ]; then
		echo -e "\n$UND${MNU}Select the upstream repo/branch$OFF"
		select_from_array brancharray "branches" repobr
	else
		repobr=${brancharray[0]}
		echo -e "$INF Only one upstream branch in this repo: $STA$repobr$OFF"
		echo -e "$INF Nothing else to choose from.$OFF"
	fi

	configtable[repobr]="$repobr"
	return 0
}

# select_localbr
# @description Choose from available local branches
#
# Globals:
# @set currentbranch string Selected branch (written)
# @set configtable array Config variables (written)
#
# Effects:
# @stdout Branch selection menu
#
# Returns:
# @exitcode 0 Always succeeds
#
select_localbr() {
	local -a branches=()

	# This git command prints the branches without decoration, since
	# there is no porcelain switch for git branch.
	mapfile -t branches <<< $(git for-each-ref --format='%(refname:short)' refs/heads/)

	if ((${#branches[@]} > 1)); then
		echo -e "\n$UND${MNU}Select the lcal branch$OFF"
		select_from_array branches "branches" currentbranch
	else
		echo -e "$INF Only one branch in this repo: $STA$currentbranch$OFF"
		echo -e "$INF Nothing else to choose from.$OFF"
	fi

	git checkout "$currentbranch"
	configtable[currentbranch]="$currentbranch"
	return 0
}

# limit_scope
# @description Limit backport log to commits before upscope
#   Comments out commits beyond scope with '#+ ' prefix.
#
# Globals:
# @set outdir string Output directory (read)
# @set bplog string Backport log filename (read)
# @set upscope string Limiting upstream commit (read)
#
# Effects:
# @stdout Modified backport log
#
# Returns:
# @exitcode 0 Always succeeds
#
limit_scope() {
	local delim=
	local line
	local -a linary=()
	local outfil="$outdir"/"$bplog"

	mapfile -t linary < "$outfil"
	> "$outfil"

	for (( i = 0; i < ${#linary[@]}; ++i)) ; do
		local tmpstr=
		local -a tmpary=()
		local cmt=
		local line="${linary[i]}"

		([ ${line:0:1} == "#" ] || [ ${line:0:1} == "+" ]) && continue

		# tokenize the line on spaces by excluding double quotes inside
		# array parens.
		tmpary=( $line )
		cmt="${tmpary[0]}"
		tmpstr="$(gitnice -1 --no-merges "$upscope"^.."$cmt")"

		[ -n "$tmpstr" ] && linary[i]="#+ $line"
	done

	echo -e "$INF"
	printf "%s\n" "${linary[@]}" | tee -a "$outfil"
	echo -e "$OFF"
	return 0
}

# show_paths
# @description Display current user-supplied paths
#
# Globals:
# @set configtable array Config with path (read)
#
# Effects:
# @stdout Formatted path list
#
# Returns:
# @exitcode 0 Always succeeds
#
show_paths() {
	local -a pthary=()
	local -i pad=32
	local padstr
	local path="${configtable[path]}"

	[ -z "$path" ] && { echo -e "\n "; return; }

	padstr="$(ui_rptchr ' ' $pad)"
	pthary=( $path )

	echo -e "$STA${pthary[0]}"
	printf "$padstr%s\n" ${pthary[@]:1}
}

# test_reqparms
# @description Test if all required parameters are present
#
# Globals:
# @set configtable array Config variables (read)
# @set exitmsgary array Exit messages (read)
#
# Effects:
# @stdout Warning for missing parameters
#
# Returns:
# @exitcode 0 All required parameters present
# @exitcode 1 Some parameters missing
#
test_reqparms() {
	local -i stat=0
	[ -n "${configtable[updir]}"  ] || { stat=1; echo -e "$WRN${exitmsgary[exit_noupdir]}"; }
	[ -n "${configtable[outdir]}" ] || { stat=1; echo -e "$WRN${exitmsgary[exit_nooutd]}"; }
	[ -n "${configtable[path]}"   ] || { stat=1; echo -e "$WRN${exitmsgary[exit_nopath]}"; }
	[ -n "${configtable[repobr]}" ] || { stat=1; echo -e "$WRN${exitmsgary[exit_norepobr]}"; }
	[ -n "${configtable[dncmt]}"  ] || { stat=1; echo -e "$WRN${exitmsgary[exit_nodncmt]}"; }
	((stat == 0)) || ui_press_any
	return $stat
}

# clear_parms
# @description Clear all config parameters
#
# Globals:
# @set configtable array Config variables (cleared)
#
# Returns:
# @exitcode 0 Always succeeds
#
clear_parms() {
	local key

	for key in "${!configtable[@]}"; do
		key=${key// /}
		configtable["$key"]=
	done
}

# show_upstreamdir
# @description Display the upstream directory
#
# Globals:
# @set configtable array Config with updir (read)
# @set b_localus bool Upstream in PWD flag (read)
#
# Effects:
# @stdout Upstream directory path
#
# Returns:
# @exitcode 0 Always succeeds
#
show_upstreamdir() {
	$b_localus && echo -n -e "${INF}default is PWD: "
	echo -e -n $STA${configtable[updir]}$OFF
	return 0
}

# delete_paths
# @description Delete search paths from the list interactively
#
# Arguments:
# @arg $1 string Variable name holding path string (by reference)
#
# Effects:
# @stdout Path selection menu
#
# Returns:
# @exitcode 0 Always succeeds
#
delete_paths() {
	local -n dp_path="$1"
	local -a pathary=()
	local -i patharysiz=
	local sel=

	pathary=( $dp_path )
	patharysiz=${#pathary[@]}

	if ((patharysiz >= 1)); then
		echo -e "\n$UND${MNU}Select the path(s) to delete$OFF"
		echo -e "${MNU}Press $qstr when you're done.$OFF"

		while ((patharysiz >=1)); do
			for((i = 0; i < $patharysiz; ++i)); do
				printf "$MNU%2s. $OFF" "$((i + 1))"
				echo "${pathary[i]}"
			done

			if loop_range_q 1 "$patharysiz" sel; then
				((--sel))
				unset pathary[sel]
				pathary=( ${pathary[@]} )
				patharysiz=${#pathary[@]}
				((patharysiz < 1)) && {
					echo -e "${WRN}No more paths to delete!$OFF"
					break
				}
			else
				break
			fi
		done
	else
		echo -e "${INF}There are no paths to delete.$OFF"
	fi
	dp_path="${pathary[@]}"
	return 0
}

