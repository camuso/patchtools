# menu_parser
# @description Parse menu input and execute action
#
# Arguments:
# @arg $1 string Menu selection character
#
# Returns:
# @exitcode 0 Continue menu loop
# @exitcode 1 Run requested (break menu loop)
#
menu_parser() {
	local mp_in="$1"

	case "$mp_in" in
		q ) exitme $exit_ok
		    ;;
		d ) getuser "Downstream RHEL commit: " dncmt
		    is_validcmtexpr && configtable[dncmt]="$dncmt"
		    ;;
		p ) getuser "Path(s) to be searched: " path
		    get_pathopt "$path" path && {
			path=$(echo "$path" | tr '\n' ' ')
			configtable[path]="$path"
		    }
		    ;;
		A ) getuser "Additional Path(s) to be searched: " addpath
		    get_pathopt "$addpath" addpath && {
			addpath=$(echo "$addpath" | tr '\n' ' ')
			path="$path $addpath"
			configtable[path]="$path"
		    }
		    ;;
		D ) delete_paths path
		    configtable[path]="$path"
		    ;;
		I ) $b_include_prereqs && b_include_prereqs=false || b_include_prereqs=true
		    ;;
		o ) getuser "Directory to receive output files: " outdir
		    get_pathopt -r "$outdir" outdir && configtable[outdir]="$outdir"
		    ;;
		u ) getuser "Upstream repo directory: " updir
		    get_pathopt -r "$updir" updir && configtable[updir]="$updir"
		    [ "$updir" == "$PWD" ] && b_localus=true || b_localus=false
		    select_remote
		    ;;
		s ) getuser "Start at this upstream commit: " upcmt
		    is_validcmtexpr "$upcmt" && configtable[upcmt]="$upcmt"
		    ;;
		e ) getuser "End at this upstream commit: " upscope
		    is_validcmtexpr "$upscope" && configtable[upscope]="$upscope"
		    ;;
		b ) select_remote
		    ;;
		B ) select_localbr
		    ;;
		C ) clear_parms
		    ;;
		r ) test_reqparms && return 1
		    ;;
		h ) ptpage -b $background "$myman"
	esac

	return 0
}

# menu_loop
# @description Main menu loop for interactive mode
#
# Returns:
# @exitcode 0 User selected run
#
menu_loop() {
	local menuin

	while :; do
		cfg_read
		show_menu
		promptgetchar "${MNU}Enter one of the above: $OFF" menuin
		# If all required params are there and user pressed 'r',
		# then break and run
		menu_parser $menuin || break
		cfg_write
	done
	return 0
}

# run
# @description Execute with current parameters to create backport logs
#
# Globals:
# @set outdir string Output directory (read)
# @set updir string Upstream directory (read)
# @set uplog string Upstream log filename
# @set dnlog string Downstream log filename
# @set bplog string Backport log filename
# @set repobr string Repo/branch (read)
# @set path string Paths to search (read)
# @set upcmt string Upstream commit (read/written)
# @set upscope string Scope limit commit (read)
#
# Effects:
# @stdout Progress and log output
#
# Returns:
# @exitcode 0 Success
#
run() {
	# If the user did not input an upstream commit, then extract the
	# upstream commit from the submitted RHEL commit, which is the most
	# recent RHEL commit under consideration, entered with the -dc option.
	# If the submitted RHEL commit does not have a corresponding upstream
	# commit, then it may be contained within the upstream base commit for
	# this RHEL kernel. In that case, upcmt=dncmt.
	# If none of those criteria are met, then exit with error messages.
	if [ -z "$upcmt" ]; then
		upcmt="$(oneup $dncmt)" || {
			git rev-list "$upbase" | grep -q -m1 "$dncmt" \
			&& upcmt="$dncmt" \
			|| exitme "$exit_invhash" "$dncmt"
		}

		# validate the $upcmt
		[[ $upcmt =~ ^[0-9A-Fa-f]+$ ]] || exitme $exit_invhash "$upcmt"
		is_validcmtexpr "$upcmt" || exitme $exit_invhash "$upcmt"

		# If the upcmt is the base kernel tag, then no need to trim
		# the upcmt to kernel short hash size.
		[ "$upcmt" == "$upbase" ] || upcmt="${upcmt:0:$khashsize}"
		configtable[upcmt]="$upcmt"
	fi

	read -r mainbranch <<< "$(git branch -r | grep origin/HEAD | cut -d'>' -f2)"

	check_log "$outdir/$uplog"
	check_log "$outdir/$dnlog"
	check_log "$outdir/$bplog"

	echo -e "${INF}Upstream branch       : $STA$repobr$OFF"
	echo -e "${INF}Upstream Start commit : $STA$upcmt$OFF"
	[ -n "$upscope" ] && 	echo -e "${INF}Upstream End Commit   : $STA$upscope$OFF"
	# echo -e "${INF}Downstream branch     : $STA$mainbranch$INF"
	echo -e "${INF}Downstream branch     : $STA$currentbranch$INF"

	if [ -n "$path" ]; then
		# If there's more than one path, show them all.
		if (($(wc -w <<< "$path") > 1)); then
			echo -e "${INF}Paths:$OFF"
			# shellcheck complains about vars without quotes, but
			# sometimes, it's what you really want.
			printf "  %s\n" $path
		else
			echo -e "${INF}Path:$OFF $path"
		fi
	fi

	echo

	# Check for potential prerequisite gaps before proceeding
	local gapfile="$outdir/prerequisite-gaps.log"
	local b_has_gaps=false
	if ! detect_prerequisite_gaps "$gapfile"; then
		b_has_gaps=true
		echo -e "\n${CAU}Gap commits written to: $STA$gapfile$OFF"
		if $b_include_prereqs; then
			echo -e "${INF}Prerequisites will be automatically included (-ip flag)$OFF"
		elif $b_interactive; then
			echo -en "${CAU}Include these prerequisites in backport.log? (y/n): $OFF"
			read -r -n1 response
			echo
			if [[ "$response" == "y" || "$response" == "Y" ]]; then
				b_include_prereqs=true
			else
				echo -en "${CAU}Continue without them? (y/n): $OFF"
				read -r -n1 response
				echo
				[[ "$response" != "y" && "$response" != "Y" ]] && return 1
			fi
		else
			echo -e "${INF}Use -ip to auto-include prerequisites, or -us with an earlier commit.$OFF"
			echo -e "${INF}You can also manually prepend $gapfile to your backport.log$OFF"
		fi
	fi

	if $b_interactive; then
		echo -en "${CAU}Press any key to proceed or CTRL-C to exit...$OFF"
		read -r -n1
		echo
	fi

	echo -e "$STA$PWD$OFF"
	echo -e "${STA}Creating $outdir/$uplog$INF"

	# Get the list of upstream commits starting from the one provided
	# as the upstream start or the one extracted from the submitted
	# RHEL commit with the -dc option.
	ui_cd "$updir"
	gitnice -r -c -d --no-merges \
		"$upcmt^..$repobr" $path 2>&1 | tee "$outdir/$uplog"
	echo
	ui_cd -
	echo -e "$STA$PWD$OFF\n"
	echo -e "${STA}Creating $outdir/$dnlog$INF"

	> "$outdir/$dnlog"
	while read line; do
		local tuc="$(cut -d' ' -f1 <<< "$line")" # upstream commit hash
		local upd="$(cut -d' ' -f3 <<< "$line")" # date of upstream commit

		# First check if this upstream commit is part of the base kernel
		# that the downstream repo was created from (e.g., v6.6). If so,
		# it's already downstream as part of the original kernel base.
		# This is faster than searching commit messages.
		if git -C "$updir" merge-base --is-ancestor "$tuc" "$upbase" 2>/dev/null; then
			echo "$line" | tee -a "$outdir/$dnlog"
			continue
		fi

		# Search for downstream commits that reference this upstream commit
		# in their commit message (standard for cherry-picked/backported commits).
		# If found, write the upstream commit line to downstream.log so that
		# compare_strings can match it against upstream.log.
		if git log --oneline --grep="$tuc" --since="$upd" -- $path 2>/dev/null | grep -q .; then
			echo "$line" | tee -a "$outdir/$dnlog"
		fi
	done < "$outdir/$uplog"

	echo
	echo -e "${STA}Creating $outdir/$bplog$INF"
	compare_strings

	# Prepend prerequisites if requested and gaps exist
	if $b_include_prereqs && $b_has_gaps && [ -f "$gapfile" ]; then
		echo -e "\n${INF}Prepending prerequisite commits to $bplog...$OFF"
		local tmpfile
		tmpfile=$(mktemp)
		# Get gap commits (skip comment header line)
		grep -v '^#' "$gapfile" > "$tmpfile"
		# Add separator comment
		echo "# === Original backport commits below ===" >> "$tmpfile"
		# Append existing backport.log
		cat "$outdir/$bplog" >> "$tmpfile"
		# Replace backport.log
		mv "$tmpfile" "$outdir/$bplog"
		echo -e "${STA}Prerequisites prepended to $outdir/$bplog$OFF"
	fi

	[ -n "$searchstr" ] && seek_str
	echo -e "$OFF"

	if [ -n "$upscope" ]; then
		limit_scope & mypid=$!
		ui_waitonproc_tty $mypid .05 "Limiting scope to $MNU$upscope$OFF. Please wait."
	fi
	return 0
}

# extract_upbase
# @description Extract upstream base kernel version from downstream tags
#
# Globals:
# @set upbase string Upstream base version (e.g., v6.6)
#
# Returns:
# @exitcode 0 Always succeeds
#
extract_upbase() {
	local ktag=
	local version=

	# Get the most recent RHEL kernel tag
	ktag="$(git tag --list 'kernel-*' --sort=-v:refname | head -n 1)"

	# Extract upstream base kernel version from the RHEL kernel tag.
	# Handle different tag formats:
	#   RHEL-9:  kernel-5.14.0-503.el9
	#   RHEL-10: kernel-ivos-qualcomm-6.12.0-220.32.el10iv
	#
	# Use regex to find version pattern (X.Y.Z or X.Y where X,Y,Z are numbers)
	if [[ "$ktag" =~ ([0-9]+\.[0-9]+)\.[0-9]+ ]]; then
		version="${BASH_REMATCH[1]}"
	elif [[ "$ktag" =~ ([0-9]+\.[0-9]+) ]]; then
		version="${BASH_REMATCH[1]}"
	else
		# Fallback to old method for backwards compatibility
		version="$(cut -d'-' -f2 <<< "$ktag")"
		version="$(cut -d. -f1-2 <<< "$version")"
	fi

	upbase="v${version}"
	return 0
}

# main
# @description Main entry point
#
# Arguments:
# @arg $@ Command line arguments
#
# Returns:
# @exitcode 0 Success
#
main() {
	local mainbranch
	local currentbranch
	local mypid

	init_env

	# Get the short size of the upstream kernel hashes.
	khashsize=$(get_khashsize)

        # Trap for control-c
        trap control_c SIGINT

	extract_upbase

	if (($# == 0 )); then
		b_interactive=true

		while :; do
			menu_loop
			run
		done
	else
		b_interactive=false
		test_help "$1"
		parseops "$@"

		[ -f .git/config ] || exitme $exit_norepo "PWD: $PWD"

		# If user did not supply the upstream repo dir in the options, and
		# there is no upstream repo in $PWD/.git/config, then exit with
		# help clue.
		if [ -z "$updir" ]; then
			git branch -r | grep -E -v "origin|$USER" ||
				exitme $exit_noupstream "PWD: $PWD"
			updir="$PWD"
			configtable[updir]="$PWD"
		fi

		[[ "$updir" == "$PWD" ]] && b_localus=true || b_localus=false

		# update the configfile before going any further
		cfg_write

		# Only prompt for branch if not already set via -ub
		[[ -z "$repobr" && -z "${configtable[repobr]}" ]] && select_remote repobr
		currentbranch=$(get_currentbranch)
		configtable[currentbranch]="$currentbranch"

		# Copy configtable values to standalone variables for run()
		dncmt="${configtable[dncmt]}"
		upcmt="${configtable[upcmt]}"
		outdir="${configtable[outdir]}"
		repobr="${configtable[repobr]}"
		path="${configtable[path]}"
		upscope="${configtable[upscope]}"
	fi

	run

	exitme $exit_ok
}

main "$@"

exitme $exit_ok

