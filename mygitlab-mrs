#!/bin/bash
#
# mygitlab-mrs - List GitLab merge requests authored by you or assigned to others
#
# Query your GitLab MRs with combinable filters for state, project name,
# title regex, and date ranges. Requires jq and lab CLI tool.
#
# This file uses shdoc-style annotations. See: https://github.com/reconquest/shdoc
#
# Common annotations:
#   @description  - Function/script description
#   @arg          - Function argument: @arg $1 type description
#   @set          - Global variable set: @set varname type description
#   @exitcode     - Exit code: @exitcode 0 description
#   @stdout       - Standard output description
#   @example      - Usage example
#
# Use 'docscript -f funcname <scriptname>' to view function documentation.
#
# Usage:
#   mygitlab-mrs                     # List all MRs
#   mygitlab-mrs -sm                 # List only merged MRs
#   mygitlab-mrs -so -p stream-9     # Open MRs in stream-9 projects
#   mygitlab-mrs -sm -da "3 months ago" -c  # Count merged in last 3 months

# Script-level variables
declare config_file="$HOME/.config/lab/lab.toml"
declare token=""

# Basic ANSI colors (work on any terminal background)
declare OFF=$'\033[0m'
declare MNU=$'\033[1;33m'    # Bold yellow - titles
declare INF=$'\033[0;36m'    # Cyan - labels
declare STA=$'\033[0;32m'    # Green - state/status
declare WRN=$'\033[0;31m'    # Red - warnings
declare HDR=$'\033[1;37m'    # Bold white - headers
declare -i b_state_open=0
declare -i b_state_merged=0
declare -i b_state_closed=0
declare project_filter=""
declare -a title_filters=()    # Multiple -t patterns are ANDed
declare date_before=""
declare date_after=""
declare -i b_count_only=0
declare -i b_labels_action=1    # Show action-needed labels (default: on)
declare -i b_labels_info=1      # Show informational labels (default: on)
declare -i b_json=0             # Output as JSON
declare author_filter=""        # Author username filter
declare -a author_ids=()       # Resolved author user IDs (may be multiple candidates)
declare usagestr="$(
cat <<EOF
$(basename "$0") [-so] [-sm] [-sc] [-p project] [-t text] [-a user] [-da date] [-db date] [-nl] [-j] [-c]

List GitLab merge requests authored by you, or by a specified developer.

By default, all your MRs are returned with both action and informational labels shown.
Use filter switches to narrow the results.

Filter Switches (all optional, can be combined):
  -so         Include open MRs
  -sm         Include merged MRs
  -sc         Include closed MRs
  -p project  Filter by project name (partial match, case-insensitive)
  -t text     Filter MR titles by text/regex (case-insensitive, multiple ANDed)
  -a user     Show MRs authored by the given user (username or "First Last" name)
  -da date    Filter MRs created after (since) the given date
  -db date    Filter MRs created before the given date
  -nl         No labels - suppress label output (labels shown by default)
  -j          Output as JSON (default is human-readable)
  -c          Print only the count of MRs matching the filter(s)
  -h          Show this help message

State switches can be combined: -so -sm shows both open and merged MRs.
Using all state switches (-so -sm -sc) is the same as the default (all MRs).

Date expressions can be in various formats, e.g.:
  2025-12-17, 17-Dec-2025, Dec-17-2025, 20251217, "2 weeks ago"

Examples:
  $(basename "$0")
      List all MRs (open, merged, and closed)

  $(basename "$0") -sm
      List only merged MRs

  $(basename "$0") -so -p stream-9
      List open MRs in projects containing "stream-9"

  $(basename "$0") -so -sm
      List both open and merged MRs

  $(basename "$0") -p "stream-10" -t "usb|xhci"
      List all MRs in "stream-10" projects with titles matching "usb" or "xhci"

  $(basename "$0") -t 'ipmi' -t '10.2'
      List MRs with titles matching BOTH "ipmi" AND "10.2"

  $(basename "$0") -sm -da 2025-01-01
      List MRs merged since January 1, 2025

  $(basename "$0") -sm -da "3 months ago" -db "1 month ago"
      List MRs merged between 3 months ago and 1 month ago

  $(basename "$0") -sm -c
      Print only the count of merged MRs

  $(basename "$0") -so -p "rhel-9" -t "net" -c
      Count open MRs in "rhel-9" projects with titles matching "net"

  $(basename "$0") -a jsmith -so
      List open MRs authored by user "jsmith"

  $(basename "$0") -a "John Smith" -so
      List open MRs authored by "John Smith" (matched by display name)

  $(basename "$0") -a jsmith -so -p "rhel-9"
      List open MRs authored by "jsmith" in "rhel-9" projects

  $(basename "$0") -so -nl
      List open MRs without label output (labels are shown by default)

EOF
)"

# usage
# @description Print usage information
#
# Effects:
# @stdout Usage text
#
usage() {
	echo -e "$usagestr"
}

# exitme
# @description Exit with code and optional message
#
# Arguments:
# @arg $1 int Exit code
# @arg $2 string Optional error message
#
# Returns:
# @exitcode As specified by $1
#
exitme() {
	local -i code="$1"
	local msg="$2"

	((code == 0)) && exit "$code"
	[[ -n "$msg" ]] && echo -e "$msg" >&2
	usage
	exit "$code"
}

# control_c
# @description Handle Ctrl-C interrupt
#
# Returns:
# @exitcode 1 Always exits with error
#
control_c() {
	echo -e "\nCtrl-c detected\nCleaning up and exiting."
	exitme 1
}

# check_jq
# @description Check if jq is installed, offer to install if not
#
# Returns:
# @exitcode 0 jq is available
# @exitcode 1 jq not available and user declined install
#
check_jq() {
	command -v jq &>/dev/null && return 0

	echo "jq is required but not installed."
	read -rp "Would you like to install jq now? (y/n): " response
	if [[ "$response" =~ ^[Yy] ]]; then
		echo "Installing jq..."
		sudo dnf install -y jq || exitme 1 "Failed to install jq"
		echo "jq installed successfully."
	else
		exitme 1 "jq is required to run this script."
	fi
	return 0
}

# check_lab
# @description Check if lab CLI is installed, offer to install if not
#
# Returns:
# @exitcode 0 lab is available
# @exitcode 1 lab not available and user declined install
#
check_lab() {
	local repo_file="/etc/yum.repos.d/_copr:copr.fedorainfracloud.org:bmeneguele:rhkernel-devtools.repo"

	command -v lab &>/dev/null && return 0

	echo "lab is required but not installed."

	if [[ ! -f "$repo_file" ]]; then
		echo -e "\nThe rhkernel-devtools COPR repo is not configured."
		echo "To install lab, you need to add the repo first:"
		echo ""
		echo "  sudo dnf copr enable bmeneguele/rhkernel-devtools"
		echo ""
		echo "Then run this script again."
		exitme 1 "Missing required repo for lab installation."
	fi

	read -rp "Would you like to install lab now? (y/n): " response
	if [[ "$response" =~ ^[Yy] ]]; then
		echo "Installing lab..."
		sudo dnf install -y lab || exitme 1 "Failed to install lab"
		echo "lab installed successfully."
	else
		exitme 1 "lab is required to run this script."
	fi
	return 0
}

# check_labconfig
# @description Check if lab.toml configuration file exists
#
# Returns:
# @exitcode 0 Config file exists
# @exitcode 1 Config file not found
#
check_labconfig() {
	if [[ ! -f "$config_file" ]]; then
		echo "lab configuration file not found at: $config_file"
		echo ""
		echo "Please run 'lab' once to configure it with your GitLab token."
		exitme 1 "Missing lab configuration."
	fi
	return 0
}

# get_token
# @description Extract API token from lab.toml configuration
#
# Globals:
# @set token string GitLab API token
#
# Returns:
# @exitcode 0 Token extracted successfully
# @exitcode 1 Could not extract token
#
get_token() {
	token=$(
		awk -F'=' '
			/^[[:space:]]*(token|api_token)[[:space:]]*=/ {
				val=$2
				gsub(/^[[:space:]]+|[[:space:]]+$/, "", val)
				gsub(/#.*/, "", val)
				gsub(/^"[[:space:]]*|[[:space:]]*"$/, "", val)
				gsub(/^'\''[[:space:]]*|[[:space:]]*'\''$/, "", val)
				if (val != "") { print val; exit }
			}
		' "$config_file"
	)

	if [[ -z "$token" ]]; then
		exitme 1 "Error: Could not extract token from $config_file"
	fi
	return 0
}

# resolve_user
# @description Resolve a GitLab username or display name to user ID(s).
#   Tries exact username match first, then falls back to a name search.
#   Populates the global author_ids array with candidate user IDs.
#
# Arguments:
# @arg $1 string GitLab username or display name (e.g., "jsmith" or "John Smith")
#
# Globals:
# @set author_ids array Populated with matched user IDs
#
# Returns:
# @exitcode 0 One or more users found
# @exitcode 1 No users found
#
resolve_user() {
	local query="$1"
	local response user_id

	# First, try exact username match
	response=$(curl -s --header "PRIVATE-TOKEN: $token" \
		"https://gitlab.com/api/v4/users?username=$query")
	user_id=$(echo "$response" | jq -r '.[0].id // empty' 2>/dev/null)

	if [[ -n "$user_id" ]]; then
		local matched_name matched_user
		matched_name=$(echo "$response" | jq -r '.[0].name')
		matched_user=$(echo "$response" | jq -r '.[0].username')
		echo "Matched: $matched_name (@$matched_user)" >&2
		author_ids=("$user_id")
		return 0
	fi

	# Fall back to search (matches username, name, and email)
	response=$(curl -s --header "PRIVATE-TOKEN: $token" \
		"https://gitlab.com/api/v4/users?search=$(printf '%s' "$query" | jq -sRr @uri)")

	local -i match_count
	match_count=$(echo "$response" | jq 'length' 2>/dev/null)

	if (( match_count == 0 )); then
		echo "Error: No GitLab user found matching '$query'." >&2
		return 1
	fi

	# Populate author_ids with all matches
	mapfile -t author_ids < <(echo "$response" | jq -r '.[].id')

	if (( match_count == 1 )); then
		local matched_name matched_user
		matched_name=$(echo "$response" | jq -r '.[0].name')
		matched_user=$(echo "$response" | jq -r '.[0].username')
		echo "Matched: $matched_name (@$matched_user)" >&2
	else
		echo "Multiple users match '$query' - querying MRs for all ${match_count} candidates..." >&2
	fi
	return 0
}

# convert_date
# @description Convert a date expression to ISO 8601 format for GitLab API
#
# Arguments:
# @arg $1 string Date expression (e.g., "2025-12-17", "2 weeks ago")
#
# Effects:
# @stdout ISO 8601 formatted date string (YYYY-MM-DDTHH:MM:SSZ)
#
# Returns:
# @exitcode 0 Date converted successfully
# @exitcode 1 Invalid date expression
#
convert_date() {
	local date_expr="$1"
	local iso_date

	iso_date=$(date -d "$date_expr" -u +"%Y-%m-%dT%H:%M:%SZ" 2>/dev/null)
	if [[ -z "$iso_date" ]]; then
		exitme 1 "Error: Invalid date expression '$date_expr'"
	fi
	echo "$iso_date"
	return 0
}

# list_mrs
# @description List merge requests with configured filters
#   Queries GitLab API and applies filters for state, project, title, and dates.
#   Handles pagination automatically.
#
# Globals:
# @set b_state_open int Include open MRs flag
# @set b_state_merged int Include merged MRs flag
# @set b_state_closed int Include closed MRs flag
# @set project_filter string Project name filter
# @set title_filters array Title text filters (multiple ANDed)
# @set date_before string Filter MRs before this date
# @set date_after string Filter MRs after this date
# @set b_count_only int Output count only flag
#
# Effects:
# @stdout JSON objects for each MR, or count if -c specified
#
# Returns:
# @exitcode 0 Success
# @exitcode 1 API error
#
list_mrs() {
	local -a all_results=()
	local -i state_count=$((b_state_open + b_state_merged + b_state_closed))

	# Strategy: use project-level API only when searching for another author's MRs.
	# For your own MRs, instance-level scope=created_by_me is more reliable.
	if [[ -n "$author_filter" ]] && [[ -n "$project_filter" ]]; then
		_query_by_project
	elif [[ -n "$author_filter" ]]; then
		resolve_user "$author_filter" || return 1
		_query_by_author_ids
	else
		author_ids=("")
		_query_by_author_ids
	fi

	return $?
}

# _fetch_mrs_page
# @description Fetch and filter a single page of MR results.
#   Applies jq transforms for all configured filters.
#   Appends matching results to all_results array.
#
# Arguments:
# @arg $1 string JSON response from GitLab API
#
# Globals (read):
# @set b_state_open, b_state_merged, b_state_closed, state_count
# @set project_filter, title_filters, author_filter
# @set b_labels_action, b_labels_info
#
# Globals (write):
# @set all_results array Accumulated MR results
#
_fetch_mrs_page() {
	local response="$1"
	local -a jq_args=()
	local tz_offset
	tz_offset=$(date +"%Z (%z)")

	local date_convert="def localdate: if . then (gsub(\"\\\\.[0-9]+Z\$\"; \"Z\") | fromdateiso8601 | strflocaltime(\"%Y-%m-%d %H:%M\") + \" $tz_offset\") else null end;"
	local jira_extract='def jiraurl: ((.description // "") | capture("(?<url>https://issues\\.redhat\\.com/browse/[A-Z]+-[0-9]+)") | .url) // "missing";'

	local jq_filter="$date_convert $jira_extract"'
	.[] | {
		project: (.references.full // .web_url),
		title: .title,
		state: .state,
		author: .author.username,
		author_name: .author.name,
		assignee: (.assignee.username // "unassigned"),
		created_at: (.created_at | localdate),
		updated_at: (.updated_at | localdate),
		merged_at: (.merged_at | localdate),
		url: .web_url,
		jira: jiraurl'

	if (( b_labels_action )); then
		jq_filter+=',
		labels_action: [.labels[] | select(
			(test("::OK$") | not) and
			(test("::None$") | not) and
			(test("^Subsystem:") | not) and
			(test("^Dependencies::") | not)
		)]'
	fi

	if (( b_labels_info )); then
		jq_filter+=',
		labels_info: [.labels[] | select(
			test("^Subsystem:") or test("^Dependencies::")
		)]'
	fi

	jq_filter+='}'

	# State filter
	if (( state_count > 0 && state_count < 3 )); then
		local -a state_conditions=()
		(( b_state_open )) && state_conditions+=('.state == "opened"')
		(( b_state_merged )) && state_conditions+=('.state == "merged"')
		(( b_state_closed )) && state_conditions+=('.state == "closed"')

		local state_expr="" first=true
		for cond in "${state_conditions[@]}"; do
			$first && state_expr="$cond" || state_expr="$state_expr or $cond"
			first=false
		done
		jq_filter+=" | select($state_expr)"
	fi

	# Project filter (client-side, for instance-level queries)
	if [[ -n "$project_filter" ]]; then
		jq_args+=(--arg pf "$project_filter")
		jq_filter+=' | select((.project // "") | test($pf; "i"))'
	fi

	# Author filter (client-side, matches username or display name)
	if [[ -n "$author_filter" ]]; then
		jq_args+=(--arg af "$author_filter")
		jq_filter+=' | select((.author // "") + " " + (.author_name // "") | test($af; "i"))'
	fi

	# Title filters (multiple -t are ANDed)
	local -i filter_idx=0
	for filter in "${title_filters[@]}"; do
		jq_args+=(--arg "tf$filter_idx" "$filter")
		jq_filter+=" | select((.title // \"\") | test(\$tf$filter_idx; \"i\"))"
		((filter_idx++))
	done

	local page_results
	page_results=$(echo "$response" | jq "${jq_args[@]}" "$jq_filter")

	if [[ -n "$page_results" ]]; then
		all_results+=("$page_results")
	fi
}

# _query_by_project
# @description Find projects matching -p filter and query their MRs directly.
#   This approach is more reliable for finding other users' MRs because it
#   doesn't require resolving user IDs from a global search.
#
_query_by_project() {
	local -a project_ids=()
	local search_response

	# The API searches project names, not paths. Extract the last path component
	# for the API search, then filter results by full path client-side.
	local search_term="${project_filter##*/}"

	echo "Searching for projects matching '$project_filter'..." >&2
	search_response=$(curl -s --header "PRIVATE-TOKEN: $token" \
		"https://gitlab.com/api/v4/projects?search=$search_term&membership=true&per_page=100")

	if ! echo "$search_response" | jq -e 'type == "array"' > /dev/null 2>&1; then
		echo "Error searching for projects." >&2
		return 1
	fi

	# Filter by full path if the user specified a path-like filter (contains /)
	mapfile -t project_ids < <(echo "$search_response" | \
		jq -r --arg pf "$project_filter" \
		'.[] | select(.path_with_namespace | test($pf; "i")) | .id')

	if (( ${#project_ids[@]} == 0 )); then
		echo "No projects found matching '$project_filter'." >&2
		return 0
	fi

	local -i proj_count=${#project_ids[@]}
	echo "Found $proj_count project(s), querying merge requests..." >&2

	# Build date filter params
	local date_params=""
	if [[ -n "$date_after" ]]; then
		local iso_after
		iso_after=$(convert_date "$date_after")
		date_params+="&created_after=$iso_after"
	fi
	if [[ -n "$date_before" ]]; then
		local iso_before
		iso_before=$(convert_date "$date_before")
		date_params+="&created_before=$iso_before"
	fi

	# Clear project_filter - project filtering already done at API level.
	# The project-level MR response uses local references (e.g. !11) that
	# won't match the filter string.
	local saved_project_filter="$project_filter"
	project_filter=""

	local -a all_authors=()
	for pid in "${project_ids[@]}"; do
		local -i page=1
		while true; do
			local response
			response=$(curl -s --header "PRIVATE-TOKEN: $token" \
				"https://gitlab.com/api/v4/projects/$pid/merge_requests?per_page=100&state=all${date_params}&page=$page")

			if ! echo "$response" | jq -e 'type == "array"' > /dev/null 2>&1; then
				break
			fi

			local -i count
			count=$(echo "$response" | jq 'length')
			(( count == 0 )) && break

			# Collect unique authors for hint if filter produces no results
			if [[ -n "$author_filter" ]]; then
				local page_authors
				page_authors=$(echo "$response" | jq -r '.[] | "\(.author.username) (\(.author.name))"' | sort -u)
				while IFS= read -r a; do
					[[ -n "$a" ]] && all_authors+=("$a")
				done <<< "$page_authors"
			fi

			_fetch_mrs_page "$response"
			((page++))
		done
	done

	project_filter="$saved_project_filter"

	# If author filter was set but produced no results, show available authors
	if [[ -n "$author_filter" ]] && (( ${#all_results[@]} == 0 && ${#all_authors[@]} > 0 )); then
		echo "No MRs matched author '$author_filter'." >&2
		echo "Authors with MRs in matching projects:" >&2
		printf '%s\n' "${all_authors[@]}" | sort -u | while IFS= read -r line; do
			echo "  $line" >&2
		done
		return 0
	fi

	_output_results
}

# _query_by_author_ids
# @description Query instance-level MRs by resolved author IDs.
#
_query_by_author_ids() {
	local base_url="https://gitlab.com/api/v4/merge_requests?per_page=100&state=all"

	if [[ -n "$date_after" ]]; then
		local iso_after
		iso_after=$(convert_date "$date_after")
		base_url+="&created_after=$iso_after"
	fi
	if [[ -n "$date_before" ]]; then
		local iso_before
		iso_before=$(convert_date "$date_before")
		base_url+="&created_before=$iso_before"
	fi

	for uid in "${author_ids[@]}"; do
		local api_url="$base_url"
		if [[ -n "$uid" ]]; then
			api_url+="&scope=all&author_id=$uid"
		else
			api_url+="&scope=created_by_me"
		fi

		local -i page=1
		while true; do
			local response
			response=$(curl -s --header "PRIVATE-TOKEN: $token" \
				"${api_url}&page=$page")

			if ! echo "$response" | jq -e 'type == "array"' > /dev/null 2>&1; then
				local error_msg
				error_msg=$(echo "$response" | jq -r '.message // .error // empty' 2>/dev/null)
				if [[ -n "$error_msg" ]]; then
					echo "GitLab API error: $error_msg" >&2
				else
					echo "Unexpected API response format" >&2
				fi
				return 1
			fi

			local -i count
			count=$(echo "$response" | jq 'length')
			(( count == 0 )) && break

			_fetch_mrs_page "$response"
			((page++))
		done
	done

	_output_results
}

# _output_results
# @description Format and output collected MR results.
#
_output_results() {
	if (( ${#all_results[@]} == 0 )); then
		if (( b_count_only )); then
			echo "0"
		elif (( ! b_json )); then
			echo "No merge requests found matching your criteria."
		fi
		return 0
	fi

	if (( b_count_only )); then
		local -i total=0
		for result in "${all_results[@]}"; do
			local -i cnt
			cnt=$(echo "$result" | jq -s 'length')
			((total += cnt))
		done
		echo "$total"
	elif (( b_json )); then
		for result in "${all_results[@]}"; do
			echo "$result"
		done
	else
		for result in "${all_results[@]}"; do
			echo "$result" | jq -r --arg MNU "$MNU" --arg INF "$INF" --arg STA "$STA" --arg WRN "$WRN" --arg OFF "$OFF" --arg aflt "$author_filter" '
				"\($MNU)\(.title)\($OFF)",
				"  \($INF)Project:\($OFF) \(.project)",
				"  \($INF)State:\($OFF) \(.state)",
				(if $aflt != "" then "  \($INF)Author:\($OFF) \(.author)" else empty end),
				"  \($INF)Assignee:\($OFF) \(.assignee)",
				"  \($INF)Created:\($OFF) \(.created_at)",
				"  \($INF)Updated:\($OFF) \(.updated_at)",
				(if .merged_at then "  \($INF)Merged:\($OFF) \(.merged_at)" else empty end),
				"  \($INF)URL:\($OFF) \(.url)",
				"  \($INF)Jira:\($OFF) \(if .jira == "missing" then "\($WRN)\(.jira)\($OFF)" else .jira end)",
				(if .labels_action then "  \($WRN)Action Labels:\($OFF) \(if (.labels_action | length) > 0 then .labels_action | join(", ") else "None" end)" else empty end),
				(if .labels_info then "  \($INF)Info Labels:\($OFF) \(.labels_info | join(", "))" else empty end),
				""
			'
		done
	fi

	return 0
}

# parse_args
# @description Parse command line arguments
#
# Arguments:
# @arg $@ string Command line arguments
#
# Globals:
# @set b_state_open int Open state filter
# @set b_state_merged int Merged state filter
# @set b_state_closed int Closed state filter
# @set project_filter string Project filter
# @set title_filters array Title text filters (multiple ANDed)
# @set date_after string After date filter
# @set date_before string Before date filter
# @set b_count_only int Count only flag
# @set author_filter string Author username filter
#
# Returns:
# @exitcode 0 Success
# @exitcode 1 Invalid argument
#
parse_args() {
	while [[ $# -gt 0 ]]; do
		case "$1" in
			-h|--help)
				usage
				exit 0
				;;
			-so)
				b_state_open=1
				;;
			-sm)
				b_state_merged=1
				;;
			-sc)
				b_state_closed=1
				;;
			-p)
				shift
				if [[ -z "$1" || "$1" == -* ]]; then
					exitme 1 "Error: -p requires a project filter string"
				fi
				project_filter="$1"
				;;
		-t)
			shift
			if [[ -z "$1" || "$1" == -* ]]; then
				exitme 1 "Error: -t requires a text pattern"
			fi
			title_filters+=("$1")
			;;
		-a)
			shift
			if [[ -z "$1" || "$1" == -* ]]; then
				exitme 1 "Error: -a requires a GitLab username or name"
			fi
			author_filter="$1"
			;;
		-da)
				shift
				if [[ -z "$1" || "$1" == -* ]]; then
					exitme 1 "Error: -da requires a date expression"
				fi
				date_after="$1"
				;;
			-db)
				shift
				if [[ -z "$1" || "$1" == -* ]]; then
					exitme 1 "Error: -db requires a date expression"
				fi
				date_before="$1"
				;;
			-c)
				b_count_only=1
				;;
			-nl)
				b_labels_action=0
				b_labels_info=0
				;;
			-j)
				b_json=1
				;;
			*)
				exitme 1 "Error: Unknown option '$1'"
				;;
		esac
		shift
	done
	return 0
}

# main
# @description Main entry point
#
# Arguments:
# @arg $@ string Command line arguments
#
# Returns:
# @exitcode 0 Success
# @exitcode 1 Error (missing deps, API error, etc.)
#
main() {
	trap control_c SIGINT

	parse_args "$@"

	# Check dependencies
	check_jq
	check_lab
	check_labconfig

	get_token
	list_mrs

	return $?
}

main "$@"
